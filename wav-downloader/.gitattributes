# Normalize line endings to LF in the repo; let git handle checkout conversion.
* text=auto eol=lf

# Binaries — no LF conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.wav  binary
*.mp3  binary
*.mp4  binary
*.zip  binary
*.db   binary
*.sqlite binary
